{
    "name": "feedex/coinex",
    "type": "library",
    "description": "Coinex PHP API wrapper - based on the Coinex official documents.",
    "license": "MIT",
    "keywords": ["coinex", "Coinex PHP API"],
    "autoload": {
        "psr-4": {
            "Feedex\\Coinex\\": "./src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Feedex\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.4",
        "feedex/feedex": "^1.0",
        "guzzlehttp/guzzle": "^7.9"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0"
    }
}
